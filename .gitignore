# BA-Kit .gitignore
# Last updated: 2026-04-12

# ============================================
# System / OS files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ============================================
# Python artifacts
# ============================================
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg

# ============================================
# Logs & Temporary files
# ============================================
*.log
logs/
*.tmp
*.temp
.cache/
*.bak
*.backup

# ============================================
# Package managers (if future tooling added)
# ============================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Build outputs
# ============================================
dist/
build/
out/

# ============================================
# BA Project outputs (deliverables, per-project)
# ============================================
outputs/*
# Exception: mini-app-cham-cong is the BA-Kit reference showcase — tracked
!outputs/mini-app-cham-cong/
!outputs/mini-app-cham-cong/**

# ============================================
# Environment files (NEVER commit secrets)
# ============================================
.env
**/.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# ============================================
# Claude Code session state (local per-machine)
# ============================================
.claude/session-state/
.claude/agent-memory/

# ============================================
# Plans & Reports (local working files)
# ============================================
plans/

# ============================================
# Local development artifacts
# ============================================
*.local.md
drafts/
scratch/

# ============================================
# Generated diagram outputs (re-generate via CLI)
# ============================================
*.mmd.svg
*.mmd.png
*.mmd.pdf

# ============================================
# BA-Kit v3.2 — runtime state (per-dev, not team-shared by default)
# ============================================
# Full .ba-kit/ is gitignored by default. Teams wanting to share baselines
# or retros across developers can selectively un-ignore subdirectories via
# local .git/info/exclude or a project-specific override.
.ba-kit/

# E2E test runner output (generated per-run)
reports/
!plans/reports/

# ============================================
# Legacy / Archived content
# ============================================
legacy/
