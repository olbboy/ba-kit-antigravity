# BA-Kit .gitignore
# Last updated: 2026-04-12

# ============================================
# System / OS files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ============================================
# Python artifacts
# ============================================
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg

# ============================================
# Logs & Temporary files
# ============================================
*.log
logs/
*.tmp
*.temp
.cache/
*.bak
*.backup

# ============================================
# Package managers (if future tooling added)
# ============================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Build outputs
# ============================================
dist/
build/
out/

# ============================================
# BA Project outputs (deliverables, per-project)
# ============================================
outputs/

# ============================================
# Environment files (NEVER commit secrets)
# ============================================
.env
**/.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# ============================================
# Claude Code session state (local per-machine)
# ============================================
.claude/session-state/
.claude/agent-memory/

# ============================================
# Plans & Reports (local working files)
# ============================================
plans/

# ============================================
# Local development artifacts
# ============================================
*.local.md
drafts/
scratch/

# ============================================
# Generated diagram outputs (re-generate via CLI)
# ============================================
*.mmd.svg
*.mmd.png
*.mmd.pdf

# ============================================
# Legacy / Archived content
# ============================================
legacy/
